FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ libgomp1 \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY src/ ./src/
RUN mkdir -p data/parquet data/reports

ENV PYTHONPATH=/app/src

# ray start --address conecta el worker al head usando el protocolo interno de Ray
CMD ["bash", "-c", "ray start --address=ray-head:6379 --block"]
